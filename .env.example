# ==============================================================================
# PATHOLOGY BITES - ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env.local and configure with your actual values
# Documentation: docs/development/ENVIRONMENT_SETUP.md

# ==============================================================================
# APPLICATION SETTINGS
# ==============================================================================
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Pathology Bites"
NEXT_PUBLIC_APP_VERSION=1.0.0

# ==============================================================================
# DATABASE & BACKEND (Required)
# ==============================================================================
# Supabase Configuration
# Get these from: https://app.supabase.com/project/[project-id]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ==============================================================================
# AUTHENTICATION & SECURITY
# ==============================================================================
# OAuth Providers
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# Rate Limiting Configuration
AUTH_RATE_LIMIT_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_BLOCK_MINUTES_DEV=2
AUTH_RATE_LIMIT_BLOCK_MINUTES_PROD=10

# Session Configuration
SESSION_TIMEOUT_MINUTES=60
SESSION_REFRESH_THRESHOLD_MINUTES=15

# ==============================================================================
# QUIZ CONFIGURATION
# ==============================================================================
NEXT_PUBLIC_MAX_QUESTIONS_PER_QUIZ=50
NEXT_PUBLIC_MIN_QUESTIONS_PER_QUIZ=5
NEXT_PUBLIC_MAX_QUIZZES_PER_DAY=50
NEXT_PUBLIC_MAX_QUESTIONS_PER_DAY=100
NEXT_PUBLIC_SECONDS_PER_QUESTION=60
NEXT_PUBLIC_AUTO_SUBMIT_QUIZ=true
NEXT_PUBLIC_SHOW_QUIZ_PROGRESS=true

# ==============================================================================
# UI/UX SETTINGS
# ==============================================================================
# Text Zoom Configuration
NEXT_PUBLIC_MIN_TEXT_ZOOM_SIZE=0.75
NEXT_PUBLIC_MAX_TEXT_ZOOM_SIZE=1.25
NEXT_PUBLIC_DEFAULT_TEXT_ZOOM_SIZE=1.0
NEXT_PUBLIC_TEXT_ZOOM_STEP=0.05

# Theme Configuration
NEXT_PUBLIC_DEFAULT_THEME=default
NEXT_PUBLIC_THEME_SWITCHING_ENABLED=true
NEXT_PUBLIC_SYSTEM_THEME_DETECTION=true

# Layout & Display
NEXT_PUBLIC_ITEMS_PER_PAGE=20
NEXT_PUBLIC_MAX_ITEMS_PER_PAGE=100
NEXT_PUBLIC_ENABLE_ANIMATIONS=true
NEXT_PUBLIC_COMPACT_MODE_AVAILABLE=true

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================
NEXT_PUBLIC_COMING_SOON_MODE=false
NEXT_PUBLIC_LAUNCH_DATE=2025-08-01
NEXT_PUBLIC_ENABLE_BETA_FEATURES=false
NEXT_PUBLIC_ENABLE_EXPERIMENTAL_FEATURES=false
NEXT_PUBLIC_MAINTENANCE_MODE=false
NEXT_PUBLIC_ENABLE_DARK_MODE=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_SEARCH=true
NEXT_PUBLIC_ENABLE_FAVORITES=true
NEXT_PUBLIC_ENABLE_COMMENTS=true
NEXT_PUBLIC_ENABLE_SHARING=true

# ==============================================================================
# CONTENT & MEDIA
# ==============================================================================
# File Upload Limits
NEXT_PUBLIC_MAX_FILE_SIZE_MB=10
NEXT_PUBLIC_MAX_IMAGE_SIZE_MB=1
NEXT_PUBLIC_ALLOWED_FILE_TYPES=jpg,jpeg,png
NEXT_PUBLIC_ENABLE_FILE_COMPRESSION=true

# Image Processing
NEXT_PUBLIC_IMAGE_QUALITY=85
NEXT_PUBLIC_ENABLE_WEBP=true
NEXT_PUBLIC_ENABLE_LAZY_LOADING=true

# ==============================================================================
# SEARCH & FILTERING
# ==============================================================================
NEXT_PUBLIC_SEARCH_MIN_CHARACTERS=2
NEXT_PUBLIC_SEARCH_DEBOUNCE_MS=300
NEXT_PUBLIC_SEARCH_MAX_RESULTS=50
NEXT_PUBLIC_ENABLE_SEARCH_SUGGESTIONS=true
NEXT_PUBLIC_ENABLE_SEARCH_HISTORY=true

# ==============================================================================
# PERFORMANCE & CACHING
# ==============================================================================
NEXT_PUBLIC_ENABLE_SERVICE_WORKER=true
NEXT_PUBLIC_CACHE_TIMEOUT_MINUTES=30
NEXT_PUBLIC_API_TIMEOUT_SECONDS=30
NEXT_PUBLIC_ENABLE_COMPRESSION=true
NEXT_PUBLIC_ENABLE_PRELOADING=true

# ==============================================================================
# ACCESSIBILITY
# ==============================================================================
NEXT_PUBLIC_ENABLE_KEYBOARD_SHORTCUTS=true
NEXT_PUBLIC_ENABLE_SCREEN_READER_SUPPORT=true
NEXT_PUBLIC_ENABLE_HIGH_CONTRAST=true
NEXT_PUBLIC_ENABLE_REDUCED_MOTION=true

# ==============================================================================
# LOCALIZATION
# ==============================================================================
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,es,fr,de
NEXT_PUBLIC_ENABLE_RTL=false
NEXT_PUBLIC_TIMEZONE=America/New_York

# ==============================================================================
# SEO & ANALYTICS
# ==============================================================================
# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=your_google_analytics_measurement_id_here

# Google Search Console verification code
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_site_verification_code_here

# ==============================================================================
# EXTERNAL SERVICES (Optional)
# ==============================================================================
# Email Service (Resend)
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM_ADDRESS=noreply@pathologybites.com
EMAIL_FROM_NAME="Pathology Bites"

# Legacy Analytics (if needed)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your_vercel_analytics_id_here
NEXT_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token_here

# Error Tracking
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here

# CDN Configuration
NEXT_PUBLIC_CDN_URL=https://cdn.pathologybites.com
NEXT_PUBLIC_MEDIA_BASE_URL=https://media.pathologybites.com

# ==============================================================================
# DEVELOPMENT & DEBUGGING (Optional)
# ==============================================================================
DEBUG=false
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_SHOW_DEBUG_INFO=false
NEXT_PUBLIC_ENABLE_LOGGING=true
NEXT_PUBLIC_LOG_LEVEL=info

# Development Tools
NEXT_PUBLIC_ENABLE_REACT_DEVTOOLS=true
NEXT_PUBLIC_ENABLE_REDUX_DEVTOOLS=true
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=false

# ==============================================================================
# BYPASS SYSTEM (Development Only)
# ==============================================================================
NEXT_PUBLIC_BYPASS_ANALYTICS=false
NEXT_PUBLIC_BYPASS_LOGGING=false
NEXT_PUBLIC_BYPASS_RATE_LIMITING=false
NEXT_PUBLIC_BYPASS_MIDDLEWARE=false
NEXT_PUBLIC_BYPASS_QUIZ_LIMITS=false
NEXT_PUBLIC_BYPASS_QUIZ_LOCK=false
NEXT_PUBLIC_BYPASS_AUTH=false
NEXT_PUBLIC_BYPASS_PERMISSIONS=false

# ==============================================================================
# NOTIFICATIONS
# ==============================================================================
NEXT_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_EMAIL_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_IN_APP_NOTIFICATIONS=true
NEXT_PUBLIC_NOTIFICATION_SOUND_ENABLED=true

# ==============================================================================
# QUICK SETUP GUIDE
# ==============================================================================
# 1. Copy this file:           cp .env.example .env.local
# 2. Get Supabase credentials: https://app.supabase.com/project/[id]/settings/api
# 3. Fill in the required values above
# 4. Start development:        npm run dev
#
# Full documentation: docs/development/ENVIRONMENT_SETUP.md

# ==============================================================================
# SECURITY REMINDERS
# ==============================================================================
# ⚠️  Never commit .env.local to version control
# ⚠️  Keep SUPABASE_SERVICE_ROLE_KEY secret (server-side only)
# ⚠️  Use different keys for dev/staging/production
# ⚠️  Rotate API keys regularly
# ⚠️  Validate all environment variables on startup