# ==============================================================================
# PATHOLOGY BITES - ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env.local and configure with your actual values
# Documentation: docs/development/ENVIRONMENT_SETUP.md

# ==============================================================================
# APPLICATION SETTINGS
# ==============================================================================
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ==============================================================================
# DATABASE & BACKEND (Required)
# ==============================================================================
# Supabase Configuration
# Get these from: https://app.supabase.com/project/[project-id]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ==============================================================================
# AUTHENTICATION & SECURITY
# ==============================================================================
# OAuth Providers
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# Rate Limiting Configuration
AUTH_RATE_LIMIT_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_BLOCK_MINUTES_DEV=2
AUTH_RATE_LIMIT_BLOCK_MINUTES_PROD=10

# ==============================================================================
# EXTERNAL SERVICES (Optional)
# ==============================================================================
# Email Service (Resend)
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# Analytics & Monitoring
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your_vercel_analytics_id_here

# ==============================================================================
# DEVELOPMENT & DEBUGGING (Optional)
# ==============================================================================
DEBUG=false

# ==============================================================================
# QUICK SETUP GUIDE
# ==============================================================================
# 1. Copy this file:           cp .env.example .env.local
# 2. Get Supabase credentials: https://app.supabase.com/project/[id]/settings/api
# 3. Fill in the required values above
# 4. Start development:        npm run dev
#
# Full documentation: docs/development/ENVIRONMENT_SETUP.md

# ==============================================================================
# SECURITY REMINDERS
# ==============================================================================
# ⚠️  Never commit .env.local to version control
# ⚠️  Keep SUPABASE_SERVICE_ROLE_KEY secret (server-side only)
# ⚠️  Use different keys for dev/staging/production
# ⚠️  Rotate API keys regularly
