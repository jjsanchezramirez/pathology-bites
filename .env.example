# ==============================================================================
# PATHOLOGY BITES - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control

# ==============================================================================
# APPLICATION
# ==============================================================================
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================
# Enable maintenance mode (redirects all pages to /maintenance)
NEXT_PUBLIC_MAINTENANCE_MODE=false

# ==============================================================================
# DATABASE (Supabase)
# ==============================================================================
# Get from: https://app.supabase.com/project/[project-id]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ==============================================================================
# STORAGE (Cloudflare R2)
# ==============================================================================
# Required for image uploads and assets
# Get from: https://dash.cloudflare.com/
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=pathology-bites-images
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# ==============================================================================
# SECURITY (Cloudflare Turnstile)
# ==============================================================================
# Get from: https://dash.cloudflare.com/?to=/:account/turnstile
# Test key (always passes): 1x00000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITEKEY=your_turnstile_sitekey
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# ==============================================================================
# EMAIL SERVICE (Resend)
# ==============================================================================
# Required for contact form
# Get from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key

# ==============================================================================
# SEO & ANALYTICS
# ==============================================================================
# Optional - improves SEO and provides usage analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_code

# ==============================================================================
# EXTERNAL APIs
# ==============================================================================
# Semantic Scholar - Academic paper search and citations
# Get from: https://www.semanticscholar.org/product/api#api-key-form
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_key

# OncoKB - Somatic variant oncogenicity annotation
# Get from: https://www.oncokb.org/account/settings
ONCOKB_API_KEY=your_oncokb_key

# ==============================================================================
# AI SERVICES (for question generation)
# ==============================================================================
# ⚠️  WARNING: These are exposed to client-side code
# Only use for development or implement server-side proxies

# Get API keys from:
# - LLAMA: https://llama.meta.com/llama-downloads/
# - Groq: https://console.groq.com/
# - Gemini: https://makersuite.google.com/app/apikey
# - Claude: https://console.anthropic.com/
# - OpenAI: https://platform.openai.com/api-keys
# - Mistral: https://console.mistral.ai/
# - DeepSeek: https://platform.deepseek.com/

NEXT_PUBLIC_LLAMA_API_KEY=your_llama_key
NEXT_PUBLIC_GROQ_API_KEY=your_groq_key
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_key
NEXT_PUBLIC_CLAUDE_API_KEY=your_claude_key
NEXT_PUBLIC_OPENAI_API_KEY=your_openai_key
NEXT_PUBLIC_MISTRAL_API_KEY=your_mistral_key
NEXT_PUBLIC_DEEPSEEK_API_KEY=your_deepseek_key

# ==============================================================================
# QUICK START
# ==============================================================================
# 1. Copy this file:
#    cp .env.example .env.local
#
# 2. Required for basic functionality:
#    - Supabase credentials (all 3 variables)
#    - Cloudflare R2 credentials (for images)
#
# 3. Optional for full functionality:
#    - Turnstile keys (for CAPTCHA)
#    - Resend API key (for contact form)
#    - Analytics IDs (for tracking)
#    - AI API keys (for question generation)
#
# 4. Start development:
#    npm run dev

# ==============================================================================
# SECURITY NOTES
# ==============================================================================
# ⚠️  Never commit .env.local to version control
# ⚠️  Keep SUPABASE_SERVICE_ROLE_KEY secret (server-side only)
# ⚠️  Use different keys for dev/staging/production
# ⚠️  Rotate API keys regularly
