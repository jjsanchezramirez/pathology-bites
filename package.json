    "clsx": "^2.1.1",
    "compressorjs": "^1.2.1",
    "date-fns": "^4.1.0",
    "diff": "^8.0.3",
    "jspdf": "^4.0.0",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.511.0",
    "next": "^15.5.9",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.56.4",
