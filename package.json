    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "happy-dom": "^20.6.1",
