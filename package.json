{
  "name": "pathology-bites",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "tailwind": "tailwindcss --input ./src/styles/globals.css --output ./src/styles/output.css",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "lint:knip": "npx knip --no-exit-code",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf .next",
    "clean-build": "rm -rf .next && npm run build",
    "cleanup": "npm dedupe && npm prune && eslint --fix .",
    "dev:turbo": "next dev --turbo",
    "type-check": "tsc --noEmit",
    "assign-colors": "tsx dev/scripts/assign-category-colors.ts",
    "assign-colors:apply": "tsx dev/scripts/assign-category-colors.ts --apply",
    "optimize-egress": "tsx src/scripts/complete-egress-optimization.ts",
    "migrate-assets": "tsx src/scripts/migrate-static-assets.ts",
    "update-asset-refs": "tsx src/scripts/update-asset-references.ts",
    "generate-search-index": "node dev/scripts/generate-virtual-slides-search-v2.js",
    "generate-diagnostic-index": "tsx dev/scripts/generate-search-index-optimized.ts",
    "find-unused": "npx knip --no-exit-code",
    "find-unused:custom": "npx tsx dev/scripts/find-unused-code.ts",
    "prebuild": "node -e \"process.exit(process.env.CLOUDFLARE_ACCOUNT_ID&&process.env.CLOUDFLARE_ACCESS_KEY_ID&&process.env.CLOUDFLARE_SECRET_ACCESS_KEY?0:1)\" && npm run generate-search-index || echo 'Skipping search index generation (missing R2 credentials)'",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --reporter=verbose",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:api": "playwright test dev/test/e2e/api",
    "test:all": "npm run test:run && npm run test:e2e",
    "test:ci": "vitest run --reporter=verbose && playwright test"
  },
