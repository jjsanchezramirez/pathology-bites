# ==============================================================================
# PATHOLOGY BITES - GIT IGNORE CONFIGURATION
# ==============================================================================
# Documentation: https://git-scm.com/docs/gitignore

# ==============================================================================
# DEPENDENCIES & PACKAGE MANAGERS
# ==============================================================================
node_modules/
.npm/

# ==============================================================================
# BUILD OUTPUTS & CACHE
# ==============================================================================
# Next.js
.next/
out/
build/
dist/

# TypeScript
*.tsbuildinfo
# Note: next-env.d.ts is auto-generated but should be committed for type safety

# Testing
coverage/
.nyc_output/

# ==============================================================================
# ENVIRONMENT
# ==============================================================================
.env
.env.*
*.env
# Exception: .env.example should be committed
!.env.example

# ==============================================================================
# DEVELOPMENT & DEBUGGING
# ==============================================================================
# Logs
*.log
npm-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# ==============================================================================
# OPERATING SYSTEM FILES
# ==============================================================================
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# ==============================================================================
# DEPLOYMENT & HOSTING
# ==============================================================================
.vercel

# ==============================================================================
# IDE & EDITOR FILES
# ==============================================================================
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ==============================================================================
# TEMPORARY & MISC FILES
# ==============================================================================
*.tmp
*.temp
.cache/
.parcel-cache/

# ==============================================================================
# PROJECT DIRECTORIES (PRIVATE)
# ==============================================================================
# Development-only files (docs, scripts, etc.) - keep local
dev/

# ==============================================================================
# EXPERIMENTAL & WIP CODE
# ==============================================================================
# Work-in-progress features not yet part of main app
src/wip/